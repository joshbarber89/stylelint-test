{
  "name": "test",
  "version": "1.0.0",
  "publishConfig": {
    "tag": "dev"
  },
  "engines": {
    "node": ">=20.10.0",
    "yarn": ">=3.2.3"
  },
  "packageManager": "yarn@4.6.0",
  "type": "module",
  "scripts": {
    "lint": "npx stylelint \"./src/**/*.{vue,scss}\" --config stylelint.config.mjs"
  },
  "dependencies": {
    "postcss": "^8.5.3",
    "postcss-html": "^1.8.0",
    "postcss-scss": "^4.0.9",
    "sass": "^1.81.0",
    "stylelint": "^17.4.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-formatter-pretty": "^4.0.1",
    "vue": "^3.5.13"
  },
  "files": [
    "dist/*",
    "gulpfile.js"
  ],
  "sideEffects": [
    "*.scss",
    "*.css",
    "*.vue"
  ],
  "main": "./dist/index.ts",
  "module": "./dist/index.ts",
  "exports": {
    "./*": "./dist/*",
    ".": {
      "import": "./dist/index.ts"
    }
  },
  "types": "./dist/types/index.d.ts"
}
